#!/usr/bin/env python

import os
import numpy as np
from glob import glob
from dlnpyutils import utils as dln,job_daemon as jd
from argparse import ArgumentParser
from datetime import datetime
from astropy.table import Table,vstack
import socket

if __name__ == "__main__":
    parser = ArgumentParser(description='Run 2MASS PSF photometry')
    #parser.add_argument('--files', type=str, nargs='+', default='', help='Spectrum FITS files or list')
    parser.add_argument('--nmulti', type=str, nargs=1, default=10, help='Number of parallel threads to run')
    parser.add_argument('--ntasks', type=str, nargs=1, default=-1, help='Number of tasks to run. Default is all')
    parser.add_argument('-r','--redo', action='store_true', help='Redo/clobber')
    args = parser.parse_args()
    nmulti = int(np.atleast_1d(args.nmulti)[0])
    ntasks = int(np.atleast_1d(args.ntasks)[0])
    redo = args.redo

    script = '/home/dnidever/projects/tmasspsf/bin/tmasspsf'
    basedir = '/net/dl2/dnidever/2mass/'
    outdir = basedir+'results/'
    logdir = basedir+'logs/'
    imagedir = basedir+'images/'
    images = glob(imagedir+'?/*.fits.gz')
    images.sort() 
    ibase = [os.path.basename(f) for f in images]
    print(len(images),'2MASS images')

    # Remove images that are being processed already
    prevtasklists = glob(logdir+'tmasspsf_tasks.*.*.fits')
    if len(prevtasklists)>0 and redo==False:
        prevtasks = []
        for f in prevtasklists:
            prevtasks.append(Table.read(f))
        prevtasks = vstack(prevtasks)
    
        import pdb; pdb.set_trace()


    # Remove images that have already been processed
    if redo==False:
        cfiles = glob('/net/dl2/dnidever/2mass/results/?/*.fits.gz')
        cfiles.sort()
        cbase = [os.path.basename(f) for f in cfiles]
        _,ind1,ind2 = np.intersect1d(cbase,ibase,return_indices=True)
        print(len(ind1),'already processed')
        if len(ind1)>0:
            files = np.delete(images,ind2)
        else:
            files = images
    else:
        files = images

    print(len(files),'files to process')

    # Limit tasks
    if ntasks > 0 and len(files) > ntasks:
        print('Limiting tasks to',ntasks)
        ntorun = ntasks
    else:
        ntorun = len(files)
    
    dt = [('cmd',str,200),('dir',str,200)]
    tasks = np.zeros(ntorun,dtype=np.dtype(dt))
    for i in range(ntorun):
        file1 = files[i]
        band = os.path.basename(os.path.dirname(file1))
        cmd = script+' '+file1
        tasks['cmd'][i] = cmd
        tasks['dir'][i] = outdir+band+'/'

    # Now shuffle
    np.random.seed(0)
    np.random.shuffle(tasks)

    # Save the tasks file
    hostname = socket.gethostname()
    host = hostname.split('.')[0]
    timestamp = datetime.now().strftime("%Y%m%d%H%M%S")
    taskfile = logdir+'tmasspsf_tasks.'+host+'.'+timestamp+'.fits'
    print('Writing tasks file to',taskfile)
    Table(tasks).write(taskfile,overwrite=True)

    # Start the job daemon
    jobs = jd.job_daemon(tasks['cmd'],tasks['dir'],nmulti=nmulti,prefix='tmpsf',hyperthread=True)

